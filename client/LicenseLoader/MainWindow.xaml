<Window x:Class="LicenseLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Harvcious Loader"
        Height="600" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#0d0d0f"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>

        <!-- ═══ COLORS ═══ -->
        <SolidColorBrush x:Key="WinBg"       Color="#0d0d0f"/>
        <SolidColorBrush x:Key="SurfaceBg"   Color="#111114"/>
        <SolidColorBrush x:Key="CardBg"       Color="#16161c"/>
        <SolidColorBrush x:Key="InputBg"      Color="#16161c"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#1e1e2a"/>
        <SolidColorBrush x:Key="BorderHover"  Color="#2e2e40"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#7F77DD"/>
        <SolidColorBrush x:Key="AccentDark"   Color="#534AB7"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#d0d0e0"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#55556a"/>
        <SolidColorBrush x:Key="DimBrush"     Color="#33334a"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#639922"/>
        <SolidColorBrush x:Key="SuccessDim"   Color="#1a2a0a"/>
        <SolidColorBrush x:Key="DangerBrush"  Color="#E24B4A"/>
        <SolidColorBrush x:Key="DangerDim"    Color="#1f0a0a"/>
        <SolidColorBrush x:Key="TitleBarBg"   Color="#0d0d10"/>

        <!-- ═══ TITLEBAR CLOSE BUTTON ═══ -->

        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="Dot" Width="13" Height="13" Fill="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXT INPUT ═══ -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PASSWORD INPUT ═══ -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PRIMARY BUTTON (lightweight — no blur / scale animations) ═══ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="#6A63C8"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ GHOST BUTTON ═══ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a1a28"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SUCCESS BUTTON ═══ -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27500A"/>
            <Setter Property="Foreground" Value="#97C459"/>
        </Style>

        <!-- ═══ SECONDARY BUTTON ═══ -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#252535"/>
        </Style>

        <!-- ═══ HERO LOAD HACKS (centered, no heavy effects) ═══ -->
        <Style x:Key="HeroLoadButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{StaticResource AccentDark}"
                                CornerRadius="10"
                                BorderBrush="#5a5288"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#9B93F0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#9B93F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#3a3850"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SCROLLBAR ═══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#252535" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══ OUTER SHELL WITH BORDER ═══ -->
    <Border Background="{StaticResource SurfaceBg}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="14"
            x:Name="RootShell">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- static accent (no blur — cheap to render) -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    IsHitTestVisible="False"
                    Panel.ZIndex="0"
                    Opacity="0.14"
                    CornerRadius="14"
                    Margin="0,0,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                        <GradientStop Color="#7F77DD" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Panel.ZIndex="1"
                    Background="{StaticResource TitleBarBg}"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="14,10,14,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Style="{StaticResource TitleBarBtn}" Background="#E24B4A" Margin="0,0,6,0" Click="CloseBtn_Click" ToolTip="Hide (stays in background until game closes)"/>
                        <Button Style="{StaticResource TitleBarBtn}" Background="#EF9F27" Margin="0,0,6,0" ToolTip="Minimize" Click="MinimizeBtn_Click"/>
                        <Button Style="{StaticResource TitleBarBtn}" Background="#639922" ToolTip=""/>
                    </StackPanel>
                    <TextBlock Text="HARVCIOUS LOADER"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource DimBrush}"/>

                </Grid>
            </Border>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="1" Panel.ZIndex="1"
                    Background="{StaticResource TitleBarBg}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Padding="22,14,22,14">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Harvcious Loader"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Secure license gateway"
                                   FontSize="11"
                                   Foreground="{StaticResource DimBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <!-- shield icon area -->
                    <Border Width="38" Height="38"
                            HorizontalAlignment="Right"
                            Background="{StaticResource CardBg}"
                            BorderBrush="#252535"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="⛨" FontSize="18"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ PANEL AREA ═══ -->
            <Grid Grid.Row="2" Panel.ZIndex="1" Margin="22,20,22,0">

                <!-- LOGIN -->
                <Border x:Name="PanelLogin"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Welcome back"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Sign in to continue"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="USERNAME" Foreground="{StaticResource DimBrush}"
                                   FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <TextBox x:Name="TxtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                        <TextBlock Text="PASSWORD" Foreground="{StaticResource DimBrush}"
                                   FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,14"/>

                        <TextBlock x:Name="LblLoginError"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,10" Visibility="Collapsed"/>

                        <Button Content="Sign in" Click="Login_Click"
                                Style="{StaticResource PrimaryButton}" Margin="0,6,0,8"/>

                        <!-- divider -->
                        <Grid Margin="0,2,0,10">
                            <Separator Background="{StaticResource BorderColor}"/>
                            <Border Background="{StaticResource CardBg}" HorizontalAlignment="Center" Padding="10,0">
                                <TextBlock Text="or" FontSize="11" Foreground="{StaticResource DimBrush}"/>
                            </Border>
                        </Grid>

                        <Button Content="Create account" Click="Register_Click" Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </Border>

                <!-- REGISTER -->
                <Border x:Name="PanelRegister" Visibility="Collapsed"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Create account"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="USERNAME" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <TextBox x:Name="TxtRegUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="EMAIL" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <TextBox x:Name="TxtRegEmail" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="PASSWORD" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <PasswordBox x:Name="TxtRegPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12"/>

                        <TextBlock x:Name="LblRegError"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,10" Visibility="Collapsed"/>

                        <Button Content="Register" Click="RegisterSubmit_Click"
                                Style="{StaticResource PrimaryButton}" Margin="0,6,0,8"/>
                        <Button Content="Back to sign in" Click="BackToLogin_Click" Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </Border>

                <!-- LICENSE ACTIVATE -->
                <Border x:Name="PanelLicense" Visibility="Collapsed"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel VerticalAlignment="Center">
                        <!-- key icon -->
                        <Border Width="52" Height="52" CornerRadius="14"
                                Background="{StaticResource SurfaceBg}"
                                BorderBrush="#252535" BorderThickness="1"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="🗝" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Activate license"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Enter the key you received after purchase"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="LICENSE KEY" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,5" FontWeight="Medium"/>
                        <TextBox x:Name="TxtLicenseKey" Style="{StaticResource ModernTextBox}"
                                 FontFamily="Consolas" CharacterCasing="Upper"
                                 Margin="0,0,0,14"/>

                        <TextBlock x:Name="LblLicenseError"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,10" Visibility="Collapsed"/>

                        <Button Content="Activate license" Click="Activate_Click" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Border>

                <!-- EXPIRED -->
                <Border x:Name="PanelExpired" Visibility="Collapsed"
                        Background="{StaticResource DangerDim}"
                        BorderBrush="#2a1010"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- expired icon circle -->
                        <Border Width="60" Height="60" CornerRadius="30"
                                Background="#1a0808" BorderBrush="#2a1010" BorderThickness="1"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="✕" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="LblExpiredTitle"
                                   Text="Your license has expired"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="LblExpiredDetail"
                                   Text="Your license time has ended. You cannot use the loader until you renew."
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="320" Margin="0,0,0,20"/>

                        <!-- discord contact pill -->
                        <Border Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1" CornerRadius="999"
                                Padding="16,8" HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Discord: " FontSize="12" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                
                                <TextBlock>
                                    <Run x:Name="RunDiscord" Text="ceoharvey24"
                                         Foreground="{StaticResource AccentBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Content="Enter new license key"
                                Click="GoToLicenseFromExpired_Click"
                                Style="{StaticResource PrimaryButton}"
                                Width="260" Margin="0,0,0,8"/>
                        <Button Content="Sign out" Click="SignOut_Click"
                                Style="{StaticResource GhostButton}" Width="260"/>
                    </StackPanel>
                </Border>

                <!-- MAIN DASHBOARD -->
                <Border x:Name="PanelMain" Visibility="Collapsed"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <StackPanel Margin="20,18,20,20">

                            <!-- user + status row -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- avatar -->
                                    <Border Width="36" Height="36" CornerRadius="18"
                                            Background="#1a1a28" BorderBrush="#252535" BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="CH" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock x:Name="LblWelcome"
                                                   Text="Welcome, user"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="Member"
                                                   FontSize="11" Foreground="{StaticResource DimBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Sign out"
                                        Click="SignOut_Click"
                                        FontSize="11"
                                        Foreground="{StaticResource DimBrush}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Padding="0"/>
                            </Grid>

                            <!-- stat cards -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status card -->
                                <Border Grid.Column="0" Background="{StaticResource SurfaceBg}"
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,10"
                                        x:Name="StatCard1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                                                    <Setter Property="Background" Value="#18182a"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="STATUS" FontSize="9" FontWeight="Medium"
                                                   Foreground="{StaticResource DimBrush}" Margin="0,0,0,4"/>
                                        <TextBlock>
                                            <Run x:Name="RunLicenseStatus" Text="ACTIVE"
                                                 FontSize="13" FontWeight="SemiBold"
                                                 Foreground="{StaticResource SuccessBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Expires card -->
                                <Border Grid.Column="2" Background="{StaticResource SurfaceBg}"
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                                                    <Setter Property="Background" Value="#18182a"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="EXPIRES" FontSize="9" FontWeight="Medium"
                                                   Foreground="{StaticResource DimBrush}" Margin="0,0,0,4"/>
                                        <TextBlock>
                                            <Run x:Name="RunExpires" Text="—"
                                                 FontSize="13" FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Remaining card -->
                                <Border Grid.Column="4" Background="{StaticResource SurfaceBg}"
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                                                    <Setter Property="Background" Value="#18182a"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="REMAINING" FontSize="9" FontWeight="Medium"
                                                   Foreground="{StaticResource DimBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="RunRemaining"
                                                   Text="00:00:00"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- game card -->
                            <Border Background="{StaticResource SurfaceBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="10"
                                    Padding="14,12" Margin="0,0,0,14">
                                <StackPanel>
                                    <!-- top row: icon + path + locate btn -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- game icon -->
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{StaticResource SurfaceBg}"
                                                BorderBrush="#252535" BorderThickness="1"
                                                Margin="0,0,10,0" Grid.Column="0">
                                            <TextBlock Text="⊞" FontSize="16"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- path info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="hyxd.exe"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBox x:Name="TxtGamePath"
                                                     IsReadOnly="True"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource DimBrush}"
                                                     FontSize="11"
                                                     TextWrapping="NoWrap"
                                                     Padding="0"
                                                     Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- locate btn -->
                                        <Button Grid.Column="2"
                                                x:Name="BtnLocateGame"
                                                Content="Locate"
                                                Click="LocateGame_Click"
                                                Height="28" Padding="12,0"
                                                FontSize="11"
                                                Background="Transparent"
                                                Foreground="{StaticResource MutedBrush}"
                                                BorderBrush="#252535" BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentDark}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- game state line -->
                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                                            Padding="0,10,0,0">
                                        <TextBlock x:Name="LblGameState"
                                                   Text="Status: waiting..."
                                                   FontSize="12"
                                                   Foreground="{StaticResource DimBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- start game -->
                            <Button x:Name="BtnStartGame"
                                    Content="▶  Deploy KO &amp; run (admin)"
                                    Click="StartGame_Click"
                                    Style="{StaticResource GhostButton}"
                                    Foreground="{StaticResource TextBrush}"
                                    Margin="0,0,0,16"
                                    IsEnabled="False"/>

                            <!-- load hacks — centered hero -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,4,0,8">
                                <TextBlock Text="READY TO INJECT"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DimBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <Button x:Name="BtnLoadHacks"
                                        Content="⚡  Load Hacks"
                                        Click="LoadHacks_Click"
                                        Style="{StaticResource HeroLoadButton}"
                                        IsEnabled="False"/>
                            </StackPanel>

                            <!-- message area -->
                            <TextBlock x:Name="LblMainMessage"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="3" Panel.ZIndex="1"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Background="{StaticResource TitleBarBg}"
                    CornerRadius="0,0,14,14"
                    Padding="22,12,22,12">
                <TextBlock x:Name="LblHint"
                           Text="Load hacks only while in-game."
                           FontSize="11" FontStyle="Italic"
                           Foreground="{StaticResource DimBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>

        </Grid>
    </Border>
</Window>
